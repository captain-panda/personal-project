# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/dsa_platform
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/dsa_platform?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/dsa_platform

# ─── Redis (OPTIONAL) ─────────────────────────────────────
# Leave blank to run without Redis (graceful degradation → L1 cache + Mongo).
REDIS_URL=

# ─── JWT ──────────────────────────────────────────────────
# Use long random strings in production (>= 32 chars). The server refuses to
# boot in production if these still contain "change_me".
JWT_ACCESS_SECRET=change_me_dev_access_secret_0123456789
JWT_REFRESH_SECRET=change_me_dev_refresh_secret_0123456789
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─── Security ─────────────────────────────────────────────
BCRYPT_COST=12

# ─── CORS / cookies ───────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ─── Rate limiting (requests / minute / IP) ───────────────
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_DATA_MAX=300
